),

joined AS (
    SELECT
        p.product_id,
        p.product_category_name,
        COALESCE(c.product_category_name_english, 'unknown') AS product_category_english,
        p.product_name_lenght,
        p.product_description_lenght,
        p.product_photos_qty,
        p.product_weight_g,
        p.product_length_cm,
        p.product_height_cm,
        p.product_width_cm
