-- ============================================================================
-- Silver Model: silver_dim_customers
-- Deskripsi    : Membersihkan dan menstandarisasi data pelanggan dari
--                raw_schema.dim_customer.
-- ============================================================================

WITH source AS (
    SELECT * FROM `public`.`dim_customer`
),

cleaned AS (
    SELECT
