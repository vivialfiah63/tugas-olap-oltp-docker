        CASE
            WHEN order_status IN ('canceled', 'unavailable') THEN TRUE
            ELSE FALSE
        END AS is_canceled,
        -- Durasi konfirmasi pesanan (approved - purchase) dalam jam
        dateDiff('second', toDateTime(order_purchase_timestamp), toDateTime(order_approved_at)) / 3600.0
            AS approval_hours
    FROM source
)
SELECT * FROM cleaned
          )
        
